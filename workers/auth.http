@baseUrl = https://agent-luhmann-api.maxlegg.workers.dev
@sessionToken = PASTE_TOKEN_HERE
@apiKey = PASTE_KEY_HERE

### 1. Sign up
POST {{baseUrl}}/api/auth/sign-up/email
Content-Type: application/json
Origin: {{baseUrl}}

{
  "email": "test2@example.com",
  "password": "password123",
  "name": "Test User"
}

### 2. Sign in (copy the "token" value from response into @sessionToken above)
POST {{baseUrl}}/api/auth/sign-in/email
Content-Type: application/json
Origin: {{baseUrl}}

{
  "email": "test2@example.com",
  "password": "password123"
}

### 3. Create API key (copy the "key" value from response into @apiKey above)
POST {{baseUrl}}/api/auth/api-key/create
Content-Type: application/json
Authorization: Bearer {{sessionToken}}
Origin: {{baseUrl}}

{
  "name": "obsidian-plugin"
}

### 4. Capture (uses @apiKey)
POST {{baseUrl}}/api/capture
Content-Type: application/json
Authorization: Bearer {{apiKey}}
Origin: {{baseUrl}}

{
  "content": "This is a test note about machine learning and neural networks."
}

### 5. Similarity (uses @apiKey)
POST {{baseUrl}}/api/similarity
Content-Type: application/json
Authorization: Bearer {{apiKey}}
Origin: {{baseUrl}}

{
  "content": "This is a test note about machine learning and neural networks."
}

### 6. Vector store sync (uses @apiKey)
POST {{baseUrl}}/api/vector-store/sync
Content-Type: application/json
Authorization: Bearer {{apiKey}}
Origin: {{baseUrl}}

{
  "notes": [
    {
      "id": "01_Zettels/test-note.md",
      "path": "01_Zettels/test-note.md",
      "content": "A zettel about artificial intelligence."
    }
  ]
}

### 7. Health check
GET {{baseUrl}}/
