@baseUrl = https://agent-luhmann-api.maxlegg.workers.dev

### 1. Sign up
# @name signUp
POST {{baseUrl}}/api/auth/sign-up/email
Content-Type: application/json
Origin: {{baseUrl}}

{
  "email": "test2@example.com",
  "password": "password123",
  "name": "Test User"
}

### 2. Sign in
# @name signIn
POST {{baseUrl}}/api/auth/sign-in/email
Content-Type: application/json
Origin: {{baseUrl}}

{
  "email": "test2@example.com",
  "password": "password123"
}

### 3. Create API key
# @name createApiKey
POST {{baseUrl}}/api/auth/api-key/create
Content-Type: application/json
Authorization: Bearer {{signIn.response.body.$.token}}
Origin: {{baseUrl}}

{
  "name": "obsidian-plugin"
}

### 4. Capture (uses API key from step 3)
POST {{baseUrl}}/api/capture
Content-Type: application/json
Authorization: Bearer {{createApiKey.response.body.$.key}}
Origin: {{baseUrl}}

{
  "content": "This is a test note about machine learning and neural networks."
}

### 5. Similarity (uses API key from step 3)
POST {{baseUrl}}/api/similarity
Content-Type: application/json
Authorization: Bearer {{createApiKey.response.body.$.key}}
Origin: {{baseUrl}}

{
  "content": "This is a test note about machine learning and neural networks."
}

### 6. Vector store sync (uses API key from step 3)
POST {{baseUrl}}/api/vector-store/sync
Content-Type: application/json
Authorization: Bearer {{createApiKey.response.body.$.key}}
Origin: {{baseUrl}}

{
  "notes": [
    {
      "id": "01_Zettels/test-note.md",
      "path": "01_Zettels/test-note.md",
      "content": "A zettel about artificial intelligence."
    }
  ]
}

### 7. Health check
GET {{baseUrl}}/
